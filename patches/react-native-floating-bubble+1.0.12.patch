+            handler.postDelayed(this, reminderInterval * 60 * 1000);
+        }
+    };
+
+    public static FloatingBubbleService getInstance() {
+        return instance;
+    }
+
+    public static String lastError = "";
+    public static String lastEvent = "never_started";
+
+    public boolean hasBubbleView() {
+        return bubbleView != null;
+    }
+
+    @Override
+    public void onCreate() {
+        super.onCreate();
+        lastEvent = "onCreate_started";
+        instance = this;
+        try {
+            windowManager = (WindowManager) getSystemService(WINDOW_SERVICE);
+            prefs = new SharedPrefsHelper(this);
+            loadConfigFromPrefs();
+            Log.d(TAG, "Service created, shouldShow=" + prefs.getShouldShow());
+            lastEvent = "onCreate_finished";
+        } catch (Exception e) {
+            lastError = "onCreate crash: " + e.getMessage();
+            Log.e(TAG, "Crash in onCreate", e);
+        }
+    }
+
+    private void loadConfigFromPrefs() {
+        tasbeehCount = prefs.getCount();
+        bubbleScale = prefs.getScale();
+        accentColor = prefs.getAccentColor();
+        showBorder = prefs.getShowBorder();
+        showReset = prefs.getShowReset();
+        reminderInterval = prefs.getReminderInterval();
+        currentDhikr = prefs.getDhikr();
+    }
+
+    @Override
+    public int onStartCommand(Intent intent, int flags, int startId) {
+        lastEvent = "onStartCommand_started";
+        try {
+            createNotificationChannel();
+            int iconResId = getResources().getIdentifier("notification_icon", "drawable", getPackageName());
+            if (iconResId == 0)
+                iconResId = android.R.drawable.ic_dialog_info;
+
+            Notification notification = new NotificationCompat.Builder(this, CHANNEL_ID)
+                    .setContentTitle("المسبحة العائمة تعمل")
+                    .setContentText("المسبحة العائمة نشطة الآن فوق التطبيقات.")
+                    .setSmallIcon(iconResId)
+                    .setPriority(NotificationCompat.PRIORITY_HIGH)
+                    .setOngoing(true)
+                    .setForegroundServiceBehavior(Notification.FOREGROUND_SERVICE_IMMEDIATE)
+                    .build();
+
+            if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.UPSIDE_DOWN_CAKE) {
+                startForeground(NOTIFICATION_ID, notification, ServiceInfo.FOREGROUND_SERVICE_TYPE_SPECIAL_USE);
+            } else {
+                startForeground(NOTIFICATION_ID, notification);
+            }
+
+            if (intent != null && intent.hasExtra("dhikr")) {
+                currentDhikr = intent.getStringExtra("dhikr");
+                prefs.saveConfig(prefs.getSize(), bubbleScale, accentColor, showBorder, showReset, reminderInterval,
+                        currentDhikr);
+            }
+
+            if (intent != null) {
+                if (intent.hasExtra("action")) {
+                    String action = intent.getStringExtra("action");
+                    if ("show".equals(action)) {
+                        int x = intent.getIntExtra("x", -1);
+                        int y = intent.getIntExtra("y", -1);
+                        
+                        // Use saved position if incoming is default/reset (-1)
+                        if (x == -1) x = prefs.getX();
+                        if (y == -1) y = prefs.getY();
+                        
+                        prefs.setShouldShow(true);
+                        prefs.savePosition(x, y);
+                        isBeingKilledBySystem = true;
+                        showFloatingBubble(x, y);
+                    } else if ("hide".equals(action)) {
+                        prefs.setShouldShow(false);
+                        isBeingKilledBySystem = false;
+                        hideFloatingBubble();
+                    } else if ("config".equals(action)) {
+                        loadConfigFromPrefs();
+                        if (bubbleView != null) {
+                            applyConfigToBubble();
+                        }
+                    } else if ("updateCount".equals(action)) {
+                        tasbeehCount = intent.getIntExtra("count", tasbeehCount);
+                        prefs.saveCount(tasbeehCount);
+                        updateCounterDisplay();
+                    }
+                } else if (prefs.getShouldShow()) {
+                    Log.d(TAG, "Restoring bubble after system restart");
+                    showFloatingBubble(prefs.getX(), prefs.getY());
+                }
+            } else if (prefs.getShouldShow()) {
+                Log.d(TAG, "Null intent - restoring bubble after system restart");
+                showFloatingBubble(prefs.getX(), prefs.getY());
+            }
+
+            handler.removeCallbacks(timerRunnable);
+            handler.postDelayed(timerRunnable, reminderInterval * 60 * 1000);
+
+            lastEvent = "onStartCommand_finished";
+        } catch (Exception e) {
+            lastError = "onStartCommand crash: " + e.getMessage();
+            Log.e(TAG, "Crash in onStartCommand", e);
+        }
+
+        return START_STICKY;
+    }
+
+    private boolean hasPermission() {
+        if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.M) {
+            return Settings.canDrawOverlays(this);
+        }
+        return true;
+    }
+
+    public void showFloatingBubble(int x, int y) {
+        Log.d(TAG, "showFloatingBubble called. x=" + x + " y=" + y + " hasPermission=" + hasPermission()
+                + " bubbleView=" + (bubbleView != null));
+        if (!hasPermission()) {
+            Log.e(TAG, "showFloatingBubble: NO OVERLAY PERMISSION! Cannot show bubble.");
+            return;
+        }
+        if (bubbleView != null) {
+            Log.w(TAG, "showFloatingBubble: bubbleView already exists, skipping.");
+            return;
+        }
+
+        try {
+            LayoutInflater inflater = (LayoutInflater) getSystemService(Context.LAYOUT_INFLATER_SERVICE);
+            bubbleView = inflater.inflate(R.layout.bubble_layout, null);
+            Log.d(TAG, "showFloatingBubble: Layout inflated OK");
+
+            int layoutType;
+            if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.O) {
+                layoutType = WindowManager.LayoutParams.TYPE_APPLICATION_OVERLAY;
+            } else {
+                layoutType = WindowManager.LayoutParams.TYPE_PHONE;
+            }
+
+            // Base dimensions
+            int baseWidthDp = 85;
+            int baseHeightDp = 115;
+            Log.d(TAG, "showFloatingBubble: bubbleScale=" + bubbleScale);
+            int widthPx = (int) TypedValue.applyDimension(TypedValue.COMPLEX_UNIT_DIP,
+                    (float) (baseWidthDp * bubbleScale), getResources().getDisplayMetrics());
+            int heightPx = (int) TypedValue.applyDimension(TypedValue.COMPLEX_UNIT_DIP,
+                    (float) (baseHeightDp * bubbleScale), getResources().getDisplayMetrics());
+            Log.d(TAG, "showFloatingBubble: widthPx=" + widthPx + " heightPx=" + heightPx);
+
+            params = new WindowManager.LayoutParams(
+                    widthPx, heightPx, layoutType,
+                    WindowManager.LayoutParams.FLAG_NOT_FOCUSABLE,
+                    PixelFormat.TRANSLUCENT);
+            params.gravity = Gravity.TOP | Gravity.LEFT;
+            params.x = x;
+            params.y = y;
+
+            applyConfigToBubble();
+            setupBubbleTouchListener();
+
+            View btnCount = bubbleView.findViewById(R.id.btn_count_tasbeeh);
+            if (btnCount != null) {
+                btnCount.setOnClickListener(new View.OnClickListener() {
+                    @Override
+                    public void onClick(View v) {
+                        hideReminder();
+                        tasbeehCount++;
+                        prefs.saveCount(tasbeehCount);
+                        updateCounterDisplay();
+                        sendBroadcast(new Intent(ACTION_BUBBLE_PRESS));
+                    }
+                });
+            }
+
+            View btnReset = bubbleView.findViewById(R.id.btn_reset_tasbeeh);
+            if (btnReset != null) {
+                btnReset.setOnClickListener(new View.OnClickListener() {
+                    @Override
+                    public void onClick(View v) {
+                        hideReminder();
+                        tasbeehCount = 0;
+                        prefs.saveCount(tasbeehCount);
+                        updateCounterDisplay();
+                        sendBroadcast(new Intent(ACTION_BUBBLE_RESET));
+                    }
+                });
+            }
+
+            windowManager.addView(bubbleView, params);
+            Log.d(TAG, "showFloatingBubble: ✅ addView SUCCESS - bubble should be visible now!");
+        } catch (IllegalStateException e) {
+            Log.w(TAG, "showFloatingBubble: View already added! Attempting cleanup.");
+            try {
+                windowManager.removeViewImmediate(bubbleView);
+                windowManager.addView(bubbleView, params);
+            } catch (Exception ignored) {}
+        } catch (Exception e) {
+            Log.e(TAG, "showFloatingBubble: ❌ FAILED to add bubble view!", e);
+            bubbleView = null; // Reset so it can be retried
+        }
+    }
+
+    public void setTasbeehCount(final int count) {
+        handler.post(new Runnable() {
+            @Override
+            public void run() {
+                tasbeehCount = count;
+                updateCounterDisplay();
+            }
+        });
+    }
+
+    public void setCurrentDhikr(final String label) {
+        handler.post(new Runnable() {
+            @Override
+            public void run() {
+                currentDhikr = label;
+                if (bubbleView != null) {
+                    applyConfigToBubble();
+                }
+            }
+        });
+    }
+
+    public void setConfig(final double scale, final String accentColor, final boolean showBorder, final boolean showReset, final int interval) {
+        handler.post(new Runnable() {
+            @Override
+            public void run() {
+                boolean needsReLayout = (bubbleScale != scale);
+                bubbleScale = scale;
+                FloatingBubbleService.this.accentColor = accentColor;
+                FloatingBubbleService.this.showBorder = showBorder;
+                FloatingBubbleService.this.showReset = showReset;
+                FloatingBubbleService.this.reminderInterval = interval;
+
+                if (bubbleView != null) {
+                    if (needsReLayout) {
+                        // Resize bubble
+                        int baseWidthDp = 85;
+                        int baseHeightDp = 115;
+                        int widthPx = (int) TypedValue.applyDimension(TypedValue.COMPLEX_UNIT_DIP,
+                                (float) (baseWidthDp * bubbleScale), getResources().getDisplayMetrics());
+                        int heightPx = (int) TypedValue.applyDimension(TypedValue.COMPLEX_UNIT_DIP,
+                                (float) (baseHeightDp * bubbleScale), getResources().getDisplayMetrics());
+                        params.width = widthPx;
+                        params.height = heightPx;
+                        windowManager.updateViewLayout(bubbleView, params);
+                    }
+                    applyConfigToBubble();
+                }
+
+                handler.removeCallbacks(timerRunnable);
+                handler.postDelayed(timerRunnable, reminderInterval * 60 * 1000);
+            }
+        });
+    }
+
+    private void setupBubbleTouchListener() {
+        if (bubbleView == null)
+            return;
+        bubbleView.setOnTouchListener(new View.OnTouchListener() {
+            private static final int TOUCH_MAX_OFFSET = 30;
+
+            @Override
+            public boolean onTouch(View v, MotionEvent event) {
+                hideReminder();
+                switch (event.getAction()) {
+                    case MotionEvent.ACTION_DOWN:
+                        initialX = params.x;
+                        initialY = params.y;
+                        initialTouchX = event.getRawX();
+                        initialTouchY = event.getRawY();
+                        return true;
+                    case MotionEvent.ACTION_MOVE:
+                        int deltaX = (int) (event.getRawX() - initialTouchX);
+                        int deltaY = (int) (event.getRawY() - initialTouchY);
+                        params.x = initialX + deltaX;
+                        params.y = initialY + deltaY;
+                        windowManager.updateViewLayout(bubbleView, params);
+                        return true;
+                    case MotionEvent.ACTION_UP:
+                        prefs.savePosition(params.x, params.y);
+                        int upDeltaX = (int) (event.getRawX() - initialTouchX);
+                        int upDeltaY = (int) (event.getRawY() - initialTouchY);
+
+                        if (Math.abs(upDeltaX) < TOUCH_MAX_OFFSET && Math.abs(upDeltaY) < TOUCH_MAX_OFFSET) {
+                            View btnCount = bubbleView.findViewById(R.id.btn_count_tasbeeh);
+                            View btnReset = bubbleView.findViewById(R.id.btn_reset_tasbeeh);
+
+                            if (isViewTouched(btnCount, event.getRawX(), event.getRawY())) {
+                                btnCount.performClick();
+                            } else if (isViewTouched(btnReset, event.getRawX(), event.getRawY())) {
+                                btnReset.performClick();
+                            }
+                        }
+                        return true;
+                }
+                return false;
+            }
+        });
+    }
+
+    private void applyConfigToBubble() {
+        if (bubbleView == null) return;
+        handler.post(new Runnable() {
+            @Override
+            public void run() {
+                try {
+                    if (bubbleView == null) return;
+                    
+                    // Ensure accentColor is valid
+                    String colorStr = accentColor;
+                    if (colorStr == null || colorStr.isEmpty() || !colorStr.startsWith("#")) {
+                        colorStr = "#B8860B"; // Default Gold
+                    }
+                    boolean isBlack = colorStr.equalsIgnoreCase("#000000");
+                    
+                    Log.d(TAG, "applyConfigToBubble: scale=" + bubbleScale + " accent=" + colorStr + " isBlack=" + isBlack);
+
+                    // 1. Root Container Size
+                    int widthPx = (int) TypedValue.applyDimension(TypedValue.COMPLEX_UNIT_DIP, (float) (85 * bubbleScale),
+                            getResources().getDisplayMetrics());
+                    int heightPx = (int) TypedValue.applyDimension(TypedValue.COMPLEX_UNIT_DIP, (float) (115 * bubbleScale),
+                            getResources().getDisplayMetrics());
+                    params.width = widthPx;
+                    params.height = heightPx;
+
+                    // 2. Body Background & Stroke
+                    View body = bubbleView.findViewById(R.id.tasbeeh_body_container);
+                    if (body != null) {
+                        body.setLayoutParams(new android.widget.FrameLayout.LayoutParams(widthPx, heightPx));
+                        try {
+                            android.graphics.drawable.Drawable bg = body.getBackground();
+                            if (bg instanceof GradientDrawable) {
+                                GradientDrawable gd = (GradientDrawable) bg.mutate();
+                                int bodyColor = Color.parseColor(colorStr);
+                                gd.setColors(new int[]{bodyColor, bodyColor});
+                                // Use a visible Grey stroke for Black theme, otherwise a dark thin stroke.
+                                gd.setStroke(4, Color.parseColor(isBlack ? "#475569" : "#1a140f"));
+                            }
+                        } catch (Exception e) { Log.e(TAG, "Error updating body bg", e); }
+                    }
+
+                    // 3. Reset Button
+                    View resetBtn = bubbleView.findViewById(R.id.btn_reset_tasbeeh);
+                    if (resetBtn != null) {
+                        int rSize = (int) TypedValue.applyDimension(TypedValue.COMPLEX_UNIT_DIP, (float) (14 * bubbleScale), getResources().getDisplayMetrics());
+                        resetBtn.getLayoutParams().width = rSize;
+                        resetBtn.getLayoutParams().height = rSize;
+                        resetBtn.setVisibility(showReset ? View.VISIBLE : View.GONE);
+                    }
+
+                    // 4. Count Button Area
+                    View countBtn = bubbleView.findViewById(R.id.btn_count_tasbeeh);
+                    if (countBtn != null) {
+                        int cSize = (int) TypedValue.applyDimension(TypedValue.COMPLEX_UNIT_DIP, (float) (45 * bubbleScale), getResources().getDisplayMetrics());
+                        countBtn.getLayoutParams().width = cSize;
+                        countBtn.getLayoutParams().height = cSize;
