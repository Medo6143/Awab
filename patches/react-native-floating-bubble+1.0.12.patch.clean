index 0000000..0d991ae
--- /dev/null
+++ b/node_modules/react-native-floating-bubble/android/src/main/java/com/reactlibrary/SharedPrefsHelper.java
@@ -0,0 +1,44 @@
+package com.reactlibrary;
+
+import android.content.Context;
+import android.content.SharedPreferences;
+
+public class SharedPrefsHelper {
+    private static final String PREF_NAME = "FloatingBubblePrefs";
+    private SharedPreferences prefs;
+
+    public SharedPrefsHelper(Context context) {
+        prefs = context.getSharedPreferences(PREF_NAME, Context.MODE_PRIVATE);
+    }
+
+    public void saveCount(int count) { prefs.edit().putInt("tasbeehCount", count).apply(); }
+    public int getCount() { return prefs.getInt("tasbeehCount", 0); }
+
+    public void savePosition(int x, int y) {
+        prefs.edit().putInt("x", x).putInt("y", y).apply();
+    }
+    public int getX() { return prefs.getInt("x", 10); }
+    public int getY() { return prefs.getInt("y", 10); }
+
+    public void saveConfig(String size, double scale, String accentColor, boolean showBorder, boolean showReset, int reminderInterval, String dhikr) {
+        prefs.edit()
+            .putString("size", size)
+            .putFloat("scale", (float)scale)
+            .putString("accentColor", accentColor)
+            .putBoolean("showBorder", showBorder)
+            .putBoolean("showReset", showReset)
+            .putInt("reminderInterval", reminderInterval)
+            .putString("dhikr", dhikr)
+            .apply();
+    }
+    public String getSize() { return prefs.getString("size", "medium"); }
+    public double getScale() { return prefs.getFloat("scale", 1.0f); }
+    public String getAccentColor() { return prefs.getString("accentColor", "#B8860B"); }
+    public boolean getShowBorder() { return prefs.getBoolean("showBorder", true); }
+    public boolean getShowReset() { return prefs.getBoolean("showReset", true); }
+    public int getReminderInterval() { return prefs.getInt("reminderInterval", 10); }
+    public String getDhikr() { return prefs.getString("dhikr", "سبحان الله"); }
+    
+    public void setShouldShow(boolean show) { prefs.edit().putBoolean("shouldShow", show).apply(); }
+    public boolean getShouldShow() { return prefs.getBoolean("shouldShow", false); }
+}
