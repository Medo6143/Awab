+package com.reactlibrary;
+
+import android.app.AlarmManager;
+import android.app.Notification;
+import android.app.NotificationChannel;
+import android.app.NotificationManager;
+import android.app.PendingIntent;
+import android.app.Service;
+import android.content.Context;
+import android.content.Intent;
+import android.graphics.Color;
+import android.graphics.PixelFormat;
+import android.graphics.drawable.GradientDrawable;
+import android.os.Build;
+import android.os.Handler;
+import android.os.IBinder;
+import android.os.SystemClock;
+import android.content.pm.ServiceInfo;
+import android.provider.Settings;
+import android.util.Log;
+import android.util.TypedValue;
+import android.view.Gravity;
+import android.view.LayoutInflater;
+import android.view.MotionEvent;
+import android.view.View;
+import android.view.WindowManager;
+import android.widget.TextView;
+import androidx.core.app.NotificationCompat;
+
+public class FloatingBubbleService extends Service {
+    private static final String TAG = "FloatingBubbleService";
+    private static final int NOTIFICATION_ID = 54321;
+    private static final String CHANNEL_ID = "floating_bubble_service";
+    private static final int RESTART_REQUEST_CODE = 12345;
+    public static final String ACTION_BUBBLE_PRESS = "com.reactlibrary.ACTION_BUBBLE_PRESS";
+    public static final String ACTION_BUBBLE_RESET = "com.reactlibrary.ACTION_BUBBLE_RESET";
+    public static final String ACTION_BUBBLE_REMOVE = "com.reactlibrary.ACTION_BUBBLE_REMOVE";
+
+    private static FloatingBubbleService instance;
+    private Handler handler = new Handler();
+    private String currentDhikr = "سبحان الله";
+    private View reminderView;
+    private View bubbleView;
+    private WindowManager windowManager;
+    private WindowManager.LayoutParams params;
+    private SharedPrefsHelper prefs;
+    private boolean isBeingKilledBySystem = true; // Track if destruction is from system kill vs user action
+
+    // config variables
+    private volatile int tasbeehCount = 0;
+    private volatile double bubbleScale = 1.0;
+    private volatile String accentColor = "#B8860B";
+    private volatile boolean showBorder = true;
+    private volatile boolean showReset = true;
+    private volatile int reminderInterval = 10;
+    private int initialX, initialY;
+    private float initialTouchX, initialTouchY;
+
+    private Runnable timerRunnable = new Runnable() {
+        @Override
+        public void run() {
+            showReminder();
+            handler.postDelayed(this, reminderInterval * 60 * 1000);
+        }
+    };
+
+    public static FloatingBubbleService getInstance() {
+        return instance;
+    }
+
+    public static String lastError = "";
+    public static String lastEvent = "never_started";
+
+    public boolean hasBubbleView() {
+        return bubbleView != null;
+    }
+
+    @Override
+    public void onCreate() {
+        super.onCreate();
+        lastEvent = "onCreate_started";
+        instance = this;
+        try {
+            windowManager = (WindowManager) getSystemService(WINDOW_SERVICE);
+            prefs = new SharedPrefsHelper(this);
+            loadConfigFromPrefs();
+            Log.d(TAG, "Service created, shouldShow=" + prefs.getShouldShow());
+            lastEvent = "onCreate_finished";
+        } catch (Exception e) {
+            lastError = "onCreate crash: " + e.getMessage();
+            Log.e(TAG, "Crash in onCreate", e);
+        }
+    }
+
+    private void loadConfigFromPrefs() {
+        tasbeehCount = prefs.getCount();
+        bubbleScale = prefs.getScale();
+        accentColor = prefs.getAccentColor();
+        showBorder = prefs.getShowBorder();
+        showReset = prefs.getShowReset();
+        reminderInterval = prefs.getReminderInterval();
+        currentDhikr = prefs.getDhikr();
+    }
+
+    @Override
+    public int onStartCommand(Intent intent, int flags, int startId) {
+        lastEvent = "onStartCommand_started";
+        try {
+            createNotificationChannel();
+            int iconResId = getResources().getIdentifier("notification_icon", "drawable", getPackageName());
+            if (iconResId == 0)
+                iconResId = android.R.drawable.ic_dialog_info;
+
+            Notification notification = new NotificationCompat.Builder(this, CHANNEL_ID)
+                    .setContentTitle("المسبحة العائمة تعمل")
+                    .setContentText("المسبحة العائمة نشطة الآن فوق التطبيقات.")
+                    .setSmallIcon(iconResId)
+                    .setPriority(NotificationCompat.PRIORITY_HIGH)
+                    .setOngoing(true)
+                    .setForegroundServiceBehavior(Notification.FOREGROUND_SERVICE_IMMEDIATE)
+                    .build();
+
+            if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.UPSIDE_DOWN_CAKE) {
+                startForeground(NOTIFICATION_ID, notification, ServiceInfo.FOREGROUND_SERVICE_TYPE_SPECIAL_USE);
+            } else {
+                startForeground(NOTIFICATION_ID, notification);
+            }
+
+            if (intent != null && intent.hasExtra("dhikr")) {
+                currentDhikr = intent.getStringExtra("dhikr");
+                prefs.saveConfig(prefs.getSize(), bubbleScale, accentColor, showBorder, showReset, reminderInterval,
+                        currentDhikr);
+            }
+
+            if (intent != null) {
+                if (intent.hasExtra("action")) {
+                    String action = intent.getStringExtra("action");
+                    if ("show".equals(action)) {
+                        int x = intent.getIntExtra("x", -1);
+                        int y = intent.getIntExtra("y", -1);
+                        
+                        // Use saved position if incoming is default/reset (-1)
+                        if (x == -1) x = prefs.getX();
+                        if (y == -1) y = prefs.getY();
+                        
+                        prefs.setShouldShow(true);
+                        prefs.savePosition(x, y);
+                        isBeingKilledBySystem = true;
+                        showFloatingBubble(x, y);
+                    } else if ("hide".equals(action)) {
+                        prefs.setShouldShow(false);
+                        isBeingKilledBySystem = false;
+                        hideFloatingBubble();
+                    } else if ("config".equals(action)) {
+                        loadConfigFromPrefs();
+                        if (bubbleView != null) {
+                            applyConfigToBubble();
+                        }
+                    } else if ("updateCount".equals(action)) {
+                        tasbeehCount = intent.getIntExtra("count", tasbeehCount);
+                        prefs.saveCount(tasbeehCount);
+                        updateCounterDisplay();
+                    }
+                } else if (prefs.getShouldShow()) {
+                    Log.d(TAG, "Restoring bubble after system restart");
+                    showFloatingBubble(prefs.getX(), prefs.getY());
+                }
+            } else if (prefs.getShouldShow()) {
+                Log.d(TAG, "Null intent - restoring bubble after system restart");
+                showFloatingBubble(prefs.getX(), prefs.getY());
+            }
+
+            handler.removeCallbacks(timerRunnable);
+            handler.postDelayed(timerRunnable, reminderInterval * 60 * 1000);
+
+            lastEvent = "onStartCommand_finished";
+        } catch (Exception e) {
+            lastError = "onStartCommand crash: " + e.getMessage();
+            Log.e(TAG, "Crash in onStartCommand", e);
+        }
+
+        return START_STICKY;
+    }
+
+    private boolean hasPermission() {
+        if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.M) {
+            return Settings.canDrawOverlays(this);
+        }
+        return true;
+    }
+
+    public void showFloatingBubble(int x, int y) {
+        Log.d(TAG, "showFloatingBubble called. x=" + x + " y=" + y + " hasPermission=" + hasPermission()
+                + " bubbleView=" + (bubbleView != null));
+        if (!hasPermission()) {
+            Log.e(TAG, "showFloatingBubble: NO OVERLAY PERMISSION! Cannot show bubble.");
+            return;
+        }
+        if (bubbleView != null) {
+            Log.w(TAG, "showFloatingBubble: bubbleView already exists, skipping.");
+            return;
+        }
+
+        try {
+            LayoutInflater inflater = (LayoutInflater) getSystemService(Context.LAYOUT_INFLATER_SERVICE);
+            bubbleView = inflater.inflate(R.layout.bubble_layout, null);
+            Log.d(TAG, "showFloatingBubble: Layout inflated OK");
+
+            int layoutType;
+            if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.O) {
+                layoutType = WindowManager.LayoutParams.TYPE_APPLICATION_OVERLAY;
+            } else {
+                layoutType = WindowManager.LayoutParams.TYPE_PHONE;
+            }
+
+            // Base dimensions
+            int baseWidthDp = 85;
+            int baseHeightDp = 115;
+            Log.d(TAG, "showFloatingBubble: bubbleScale=" + bubbleScale);
+            int widthPx = (int) TypedValue.applyDimension(TypedValue.COMPLEX_UNIT_DIP,
+                    (float) (baseWidthDp * bubbleScale), getResources().getDisplayMetrics());
+            int heightPx = (int) TypedValue.applyDimension(TypedValue.COMPLEX_UNIT_DIP,
+                    (float) (baseHeightDp * bubbleScale), getResources().getDisplayMetrics());
+            Log.d(TAG, "showFloatingBubble: widthPx=" + widthPx + " heightPx=" + heightPx);
+
+            params = new WindowManager.LayoutParams(
+                    widthPx, heightPx, layoutType,
+                    WindowManager.LayoutParams.FLAG_NOT_FOCUSABLE,
+                    PixelFormat.TRANSLUCENT);
+            params.gravity = Gravity.TOP | Gravity.LEFT;
+            params.x = x;
+            params.y = y;
+
+            applyConfigToBubble();
+            setupBubbleTouchListener();
+
+            View btnCount = bubbleView.findViewById(R.id.btn_count_tasbeeh);
+            if (btnCount != null) {
+                btnCount.setOnClickListener(new View.OnClickListener() {
+                    @Override
+                    public void onClick(View v) {
+                        hideReminder();
+                        tasbeehCount++;
+                        prefs.saveCount(tasbeehCount);
+                        updateCounterDisplay();
+                        sendBroadcast(new Intent(ACTION_BUBBLE_PRESS));
+                    }
+                });
+            }
+
+            View btnReset = bubbleView.findViewById(R.id.btn_reset_tasbeeh);
+            if (btnReset != null) {
+                btnReset.setOnClickListener(new View.OnClickListener() {
+                    @Override
+                    public void onClick(View v) {
+                        hideReminder();
+                        tasbeehCount = 0;
+                        prefs.saveCount(tasbeehCount);
+                        updateCounterDisplay();
+                        sendBroadcast(new Intent(ACTION_BUBBLE_RESET));
+                    }
+                });
+            }
+
+            windowManager.addView(bubbleView, params);
+            Log.d(TAG, "showFloatingBubble: ✅ addView SUCCESS - bubble should be visible now!");
+        } catch (IllegalStateException e) {
+            Log.w(TAG, "showFloatingBubble: View already added! Attempting cleanup.");
+            try {
+                windowManager.removeViewImmediate(bubbleView);
+                windowManager.addView(bubbleView, params);
+            } catch (Exception ignored) {}
+        } catch (Exception e) {
+            Log.e(TAG, "showFloatingBubble: ❌ FAILED to add bubble view!", e);
+            bubbleView = null; // Reset so it can be retried
+        }
+    }
+
+    public void setTasbeehCount(final int count) {
+        handler.post(new Runnable() {
+            @Override
+            public void run() {
+                tasbeehCount = count;
+                updateCounterDisplay();
+            }
+        });
+    }
+
+    public void setCurrentDhikr(final String label) {
+        handler.post(new Runnable() {
+            @Override
+            public void run() {
+                currentDhikr = label;
+                if (bubbleView != null) {
+                    applyConfigToBubble();
+                }
+            }
+        });
+    }
+
+    public void setConfig(final double scale, final String accentColor, final boolean showBorder, final boolean showReset, final int interval) {
+        handler.post(new Runnable() {
+            @Override
+            public void run() {
+                boolean needsReLayout = (bubbleScale != scale);
+                bubbleScale = scale;
+                FloatingBubbleService.this.accentColor = accentColor;
+                FloatingBubbleService.this.showBorder = showBorder;
+                FloatingBubbleService.this.showReset = showReset;
+                FloatingBubbleService.this.reminderInterval = interval;
+
+                if (bubbleView != null) {
+                    if (needsReLayout) {
+                        // Resize bubble
+                        int baseWidthDp = 85;
+                        int baseHeightDp = 115;
+                        int widthPx = (int) TypedValue.applyDimension(TypedValue.COMPLEX_UNIT_DIP,
+                                (float) (baseWidthDp * bubbleScale), getResources().getDisplayMetrics());
+                        int heightPx = (int) TypedValue.applyDimension(TypedValue.COMPLEX_UNIT_DIP,
+                                (float) (baseHeightDp * bubbleScale), getResources().getDisplayMetrics());
+                        params.width = widthPx;
+                        params.height = heightPx;
+                        windowManager.updateViewLayout(bubbleView, params);
+                    }
+                    applyConfigToBubble();
+                }
+
+                handler.removeCallbacks(timerRunnable);
+                handler.postDelayed(timerRunnable, reminderInterval * 60 * 1000);
+            }
+        });
+    }
+
+    private void setupBubbleTouchListener() {
+        if (bubbleView == null)
+            return;
+        bubbleView.setOnTouchListener(new View.OnTouchListener() {
+            private static final int TOUCH_MAX_OFFSET = 30;
+
+            @Override
+            public boolean onTouch(View v, MotionEvent event) {
+                hideReminder();
+                switch (event.getAction()) {
+                    case MotionEvent.ACTION_DOWN:
+                        initialX = params.x;
+                        initialY = params.y;
+                        initialTouchX = event.getRawX();
+                        initialTouchY = event.getRawY();
+                        return true;
+                    case MotionEvent.ACTION_MOVE:
+                        int deltaX = (int) (event.getRawX() - initialTouchX);
+                        int deltaY = (int) (event.getRawY() - initialTouchY);
+                        params.x = initialX + deltaX;
+                        params.y = initialY + deltaY;
+                        windowManager.updateViewLayout(bubbleView, params);
+                        return true;
+                    case MotionEvent.ACTION_UP:
+                        prefs.savePosition(params.x, params.y);
+                        int upDeltaX = (int) (event.getRawX() - initialTouchX);
+                        int upDeltaY = (int) (event.getRawY() - initialTouchY);
+
+                        if (Math.abs(upDeltaX) < TOUCH_MAX_OFFSET && Math.abs(upDeltaY) < TOUCH_MAX_OFFSET) {
+                            View btnCount = bubbleView.findViewById(R.id.btn_count_tasbeeh);
+                            View btnReset = bubbleView.findViewById(R.id.btn_reset_tasbeeh);
+
+                            if (isViewTouched(btnCount, event.getRawX(), event.getRawY())) {
+                                btnCount.performClick();
+                            } else if (isViewTouched(btnReset, event.getRawX(), event.getRawY())) {
+                                btnReset.performClick();
+                            }
+                        }
+                        return true;
+                }
+                return false;
+            }
+        });
+    }
+
+    private void applyConfigToBubble() {
+        if (bubbleView == null) return;
+        handler.post(new Runnable() {
+            @Override
+            public void run() {
+                try {
+                    if (bubbleView == null) return;
+                    
+                    // Ensure accentColor is valid
+                    String colorStr = accentColor;
+                    if (colorStr == null || colorStr.isEmpty() || !colorStr.startsWith("#")) {
+                        colorStr = "#B8860B"; // Default Gold
+                    }
+                    boolean isBlack = colorStr.equalsIgnoreCase("#000000");
+                    
+                    Log.d(TAG, "applyConfigToBubble: scale=" + bubbleScale + " accent=" + colorStr + " isBlack=" + isBlack);
+
+                    // 1. Root Container Size
+                    int widthPx = (int) TypedValue.applyDimension(TypedValue.COMPLEX_UNIT_DIP, (float) (85 * bubbleScale),
+                            getResources().getDisplayMetrics());
+                    int heightPx = (int) TypedValue.applyDimension(TypedValue.COMPLEX_UNIT_DIP, (float) (115 * bubbleScale),
+                            getResources().getDisplayMetrics());
+                    params.width = widthPx;
+                    params.height = heightPx;
+
+                    // 2. Body Background & Stroke
+                    View body = bubbleView.findViewById(R.id.tasbeeh_body_container);
+                    if (body != null) {
+                        body.setLayoutParams(new android.widget.FrameLayout.LayoutParams(widthPx, heightPx));
+                        try {
+                            android.graphics.drawable.Drawable bg = body.getBackground();
+                            if (bg instanceof GradientDrawable) {
+                                GradientDrawable gd = (GradientDrawable) bg.mutate();
+                                int bodyColor = Color.parseColor(colorStr);
+                                gd.setColors(new int[]{bodyColor, bodyColor});
+                                // Use a visible Grey stroke for Black theme, otherwise a dark thin stroke.
+                                gd.setStroke(4, Color.parseColor(isBlack ? "#475569" : "#1a140f"));
+                            }
+                        } catch (Exception e) { Log.e(TAG, "Error updating body bg", e); }
+                    }
+
+                    // 3. Reset Button
+                    View resetBtn = bubbleView.findViewById(R.id.btn_reset_tasbeeh);
+                    if (resetBtn != null) {
+                        int rSize = (int) TypedValue.applyDimension(TypedValue.COMPLEX_UNIT_DIP, (float) (14 * bubbleScale), getResources().getDisplayMetrics());
+                        resetBtn.getLayoutParams().width = rSize;
+                        resetBtn.getLayoutParams().height = rSize;
+                        resetBtn.setVisibility(showReset ? View.VISIBLE : View.GONE);
+                    }
+
+                    // 4. Count Button Area
+                    View countBtn = bubbleView.findViewById(R.id.btn_count_tasbeeh);
+                    if (countBtn != null) {
+                        int cSize = (int) TypedValue.applyDimension(TypedValue.COMPLEX_UNIT_DIP, (float) (45 * bubbleScale), getResources().getDisplayMetrics());
+                        countBtn.getLayoutParams().width = cSize;
+                        countBtn.getLayoutParams().height = cSize;
+                    }
+
+                    // 5. Screen Frame (Border Display)
+                    View screenFrame = bubbleView.findViewById(R.id.screen_frame);
+                    if (screenFrame != null) {
+                        int sW = (int) TypedValue.applyDimension(TypedValue.COMPLEX_UNIT_DIP, (float) (66 * bubbleScale), getResources().getDisplayMetrics());
+                        int sH = (int) TypedValue.applyDimension(TypedValue.COMPLEX_UNIT_DIP, (float) (40 * bubbleScale), getResources().getDisplayMetrics());
+                        screenFrame.getLayoutParams().width = sW;
+                        screenFrame.getLayoutParams().height = sH;
+                        try {
+                            android.graphics.drawable.Drawable fbg = screenFrame.getBackground();
+                            if (fbg instanceof GradientDrawable) {
+                                GradientDrawable fgd = (GradientDrawable) fbg.mutate();
+                                // For Black theme, make the outer screen frame border White for visibility
+                                fgd.setStroke(showBorder ? 4 : 0, Color.parseColor(isBlack ? "#FFFFFF" : colorStr));
+                                fgd.setAlpha(showBorder ? 255 : 0);
+                            }
+                        } catch (Exception e) { Log.e(TAG, "Error updating screen frame", e); }
+                    }
+
+                    // 6. Count Text & Inner Screen
+                    TextView tv = bubbleView.findViewById(R.id.tasbeeh_count_text);
+                    if (tv != null) {
+                        tv.setTextSize(TypedValue.COMPLEX_UNIT_SP, (float) (19 * bubbleScale));
+                        // Special case for Black: White numbers. Otherwise use accent color.
+                        tv.setTextColor(Color.parseColor(isBlack ? "#FFFFFF" : colorStr));
+                        try {
+                            android.graphics.drawable.Drawable sbg = tv.getBackground();
+                            if (sbg instanceof GradientDrawable) {
+                                GradientDrawable sgd = (GradientDrawable) sbg.mutate();
+                                // Inner screen should be Grey for Black theme, Black for others.
+                                int sColor = Color.parseColor(isBlack ? "#475569" : "#000000");
+                                sgd.setColors(new int[]{sColor, sColor});
+                            }
+                        } catch (Exception e) { Log.e(TAG, "Error updating inner screen", e); }
+                    }
+
+                    // 7. Finalize Layout Update
+                    updateCounterDisplay();
+                    try {
+                        if (bubbleView.getParent() != null) {
+                            windowManager.updateViewLayout(bubbleView, params);
+                        }
+                    } catch (Exception e) {}
+
+                } catch (Exception e) {
+                    Log.e(TAG, "Fatal error in applyConfigToBubble", e);
+                }
+            }
+        });
+    }
+
+    private void updateCounterDisplay() {
+        if (bubbleView != null) {
+            handler.post(new Runnable() {
+                @Override
+                public void run() {
+                    TextView tv = bubbleView.findViewById(R.id.tasbeeh_count_text);
+                    if (tv != null)
+                        tv.setText(String.valueOf(tasbeehCount));
+                }
+            });
+        }
+    }
+
+    private boolean isViewTouched(View view, float x, float y) {
+        if (view == null)
+            return false;
+        int[] location = new int[2];
+        view.getLocationOnScreen(location);
+        int left = location[0];
+        int top = location[1];
+        int right = left + view.getWidth();
+        int bottom = top + view.getHeight();
+        return x >= left && x <= right && y >= top && y <= bottom;
+    }
+
+    public void hideFloatingBubble() {
+        if (bubbleView != null) {
+            try {
+                if (bubbleView.getParent() != null) {
+                    windowManager.removeViewImmediate(bubbleView);
+                }
+            } catch (Exception e) {
+                Log.e(TAG, "Error removing bubble view", e);
+            }
+            bubbleView = null;
+            sendBroadcast(new Intent(ACTION_BUBBLE_REMOVE));
+        }
+    }
+
+
+    public void setReminderInterval(int minutes) {
+        if (minutes < 1)
+            minutes = 1;
+        if (this.reminderInterval != minutes) {
+            this.reminderInterval = minutes;
+            prefs.saveConfig(prefs.getSize(), bubbleScale, accentColor, showBorder, showReset, reminderInterval,
+                    currentDhikr);
+            handler.removeCallbacks(timerRunnable);
+            handler.postDelayed(timerRunnable, reminderInterval * 60 * 1000);
+        }
+    }
+
+    public void showReminder() {
+        if (reminderView != null)
+            return;
+        if (!hasPermission())
+            return;
+
+        handler.post(new Runnable() {
+            @Override
+            public void run() {
+                try {
+                    LayoutInflater inflater = (LayoutInflater) getSystemService(LAYOUT_INFLATER_SERVICE);
+                    reminderView = inflater.inflate(R.layout.reminder_layout, null);
+
+                    TextView tv = (TextView) reminderView.findViewById(R.id.reminder_text);
+                    if (tv != null)
+                        tv.setText(currentDhikr);
+
+                    int layoutType;
+                    if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.O) {
+                        layoutType = WindowManager.LayoutParams.TYPE_APPLICATION_OVERLAY;
+                    } else {
+                        layoutType = WindowManager.LayoutParams.TYPE_PHONE;
+                    }
+
+                    WindowManager.LayoutParams params = new WindowManager.LayoutParams(
+                            WindowManager.LayoutParams.WRAP_CONTENT,
+                            WindowManager.LayoutParams.WRAP_CONTENT,
+                            layoutType,
+                            WindowManager.LayoutParams.FLAG_NOT_FOCUSABLE,
+                            PixelFormat.TRANSLUCENT);
+
+                    params.gravity = Gravity.CENTER;
+                    windowManager.addView(reminderView, params);
+                } catch (Exception e) {
+                }
+            }
+        });
+    }
+
+    public void hideReminder() {
+        handler.post(new Runnable() {
+            @Override
+            public void run() {
+                try {
+                    if (reminderView != null) {
+                        windowManager.removeViewImmediate(reminderView);
+                    }
+                } catch (Exception e) {
+                } finally {
+                    reminderView = null;
+                }
+            }
+        });
+    }
+
+    public boolean isReminderVisible() {
+        return reminderView != null;
+    }
+
+    private void createNotificationChannel() {
+        if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.O) {
+            NotificationChannel serviceChannel = new NotificationChannel(
+                    CHANNEL_ID,
+                    "Floating Tasbeeh Service",
+                    NotificationManager.IMPORTANCE_HIGH);
+            serviceChannel.setShowBadge(false);
+            NotificationManager manager = getSystemService(NotificationManager.class);
+            if (manager != null) {
+                manager.createNotificationChannel(serviceChannel);
+            }
+        }
+    }
+
+    /**
+     * Called when the user swipes away the app from recent tasks.
+     * We schedule a restart of the service so the bubble reappears.
+     */
+    @Override
+    public void onTaskRemoved(Intent rootIntent) {
+        Log.d(TAG, "onTaskRemoved called, shouldShow=" + prefs.getShouldShow());
+        if (prefs.getShouldShow()) {
+            scheduleServiceRestart();
+        }
+        super.onTaskRemoved(rootIntent);
+    }
+
+    private void scheduleServiceRestart() {
+        try {
+            Intent restartServiceIntent = new Intent(getApplicationContext(), FloatingBubbleService.class);
+            restartServiceIntent.setPackage(getPackageName());
+
+            int flags = PendingIntent.FLAG_ONE_SHOT;
+            if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.M) {
+                flags |= PendingIntent.FLAG_IMMUTABLE;
+            }
+
+            PendingIntent restartServicePendingIntent = PendingIntent.getService(
+                    getApplicationContext(), RESTART_REQUEST_CODE, restartServiceIntent, flags);
+
+            AlarmManager alarmService = (AlarmManager) getApplicationContext().getSystemService(Context.ALARM_SERVICE);
+            if (alarmService != null) {
+                alarmService.set(
+                        AlarmManager.ELAPSED_REALTIME,
+                        SystemClock.elapsedRealtime() + 1000, // Restart after 1 second
+                        restartServicePendingIntent);
+            }
+            Log.d(TAG, "Service restart scheduled");
+        } catch (Exception e) {
+            Log.e(TAG, "Failed to schedule restart", e);
+        }
+    }
+
+    @Override
+    public void onDestroy() {
+        Log.d(TAG, "onDestroy called, shouldShow=" + prefs.getShouldShow() + ", isBeingKilledBySystem="
+                + isBeingKilledBySystem);
+
+        // Always clean up the views since they can't survive process death
+        hideFloatingBubble();
+        hideReminder();
+        handler.removeCallbacks(timerRunnable);
+
+        instance = null;
+        super.onDestroy();
+    }
+
+    @Override
+    public IBinder onBind(Intent intent) {
+        return null;
+    }
+}
